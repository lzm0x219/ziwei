---
type Props = astroHTML.JSX.SVGAttributes & {
  name: IconName;
};

type IconName =
  | "Add"
  | "Delete"
  | "Dragon"
  | "Github"
  | "Logo"
  | "Mask"
  | "Setting";

const { name, ...rest } = Astro.props;

const { default: Component } = await import(`./Icons/Icon${name}.astro`);
---

<Component {...rest} />
