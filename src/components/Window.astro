---
import { createBEM } from "@/shared/css";

const b = createBEM("window");
---

<main class={b()}>
  <div class={b("content")}>
    <slot />
  </div>
</main>

<style>
  .window {
    @apply flex h-[100vh] w-[100vw] items-center justify-center;

    &__content {
      @apply shadow-s1 flex h-[--window-height] min-h-[480px] w-[--window-width] min-w-[600px] max-w-[1200px] overflow-hidden rounded-2xl bg-[--window-content-background];
    }
  }
</style>
